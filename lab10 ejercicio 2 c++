#include <iostream>
#include <iomanip>
using namespace std;

 float calcularPromedio (int cantidad);
 
int main(){
     int cantidad;
    cout<< "--Calculadora de Promedio Academicos--"<<endl;
    cout<<" Ingrese la cantidad de calificaciones a promediar:";
    cin>>cantidad;
    if(cantidad <=0){
        cout<<"Error:La cantidad deber ser un numero positivo."<<endl;
    } else {
        float promedioFinal=calcularPromedio(cantidad);
        
        cout<<fixed<<setprecision(3);

        cout<< "\nEl promedio final de las "<<cantidad<<" calificaciones es: "<<promedioFinal<< endl;}

    return 0;
}


    float calcularPromedio(int cantidad) {
    float suma = 0;
    float calificacion;

    for (int i = 1; i <= cantidad; i++) {
        cout << "Ingrese la calificacion " << i << ": ";
        cin >> calificacion;
        suma += calificacion; 
    }

   
    return suma / cantidad;
}
