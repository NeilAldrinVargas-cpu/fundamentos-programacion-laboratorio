#include <iostream>
#include <iomanip>

using namespace std;



void leerVector(double notas[], int n);

void mostrarVector(double notas[], int n);

double calcularPromedio(double notas[], int n);

double buscarMayorNota(double notas[], int n);

double buscarMenorNota(double notas[], int n);

void mostrarResultados(double promedio,
                       double mayorNota,
                       double menorNota);



int main() {

    int n;


    do {
        cout << "Ingrese la cantidad de estudiantes: ";
        cin >> n;
        if (n <= 0) {
            cout << "La cantidad debe ser mayor a 0. Intente de nuevo." << endl;
        }
    } while (n <= 0);


    double notas[n];

    double promedio;
    double mayorNota;
    double menorNota;

    // Llamadas a las funciones siguiendo tu estructura exacta
    leerVector(notas, n);

    mostrarVector(notas, n);

    promedio = calcularPromedio(notas, n);

    mayorNota = buscarMayorNota(notas, n);

    menorNota = buscarMenorNota(notas, n);

    mostrarResultados(promedio, mayorNota, menorNota);

    return 0;
}



void leerVector(double notas[], int n) {

    for(int i = 0; i < n; i++) {


        do {
            cout << "Ingrese la nota del estudiante "
                 << i + 1 << " (0 - 100): ";
            cin >> notas[i];

            if (notas[i] < 0 || notas[i] > 100) {
                cout << "Nota invalida. El rango correcto es de 0 a 100." << endl;
            }
        } while (notas[i] < 0 || notas[i] > 100);
    }
}

void mostrarVector(double notas[], int n) {

    cout << "\n===== NOTAS REGISTRADAS ====="
         << endl;

    for(int i = 0; i < n; i++) {

        cout << "Estudiante "
             << i + 1
             << ": "
             << notas[i]
             << " puntos"
             << endl;
    }
}

double calcularPromedio(double notas[], int n) {

    double suma = 0;

    for(int i = 0; i < n; i++) {

        suma = suma + notas[i];
    }

    return suma / n;
}

double buscarMayorNota(double notas[], int n) {

    double mayor = notas[0];

    for(int i = 1; i < n; i++) {

        if(notas[i] > mayor) {

            mayor = notas[i];
        }
    }

    return mayor;
}

double buscarMenorNota(double notas[], int n) {

    double menor = notas[0];

    for(int i = 1; i < n; i++) {

        if(notas[i] < menor) {

            menor = notas[i];
        }
    }

    return menor;
}

void mostrarResultados(double promedio,
                       double mayorNota,
                       double menorNota) {
    cout <<fixed<<setprecision(4);
    cout << "\n==== Resultado ====="
         << endl;

    cout << "Promedio general: "
         << promedio
         << endl;

    cout << "Nota mayor: "
         << mayorNota
         << endl;

    cout << "Nota menor: "
         << menorNota
         << endl;
}
